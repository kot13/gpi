# Staging environment — copy to .env on VPS only. NEVER commit .env to git.
#
# cp .env.staging.example .env
# nano .env   # fill real values on the server

# PostgreSQL connection string (local on staging VPS)
DATABASE_URI=postgresql://USER:PASSWORD@127.0.0.1:5432/gpi_staging

# Used to encrypt JWT tokens (min 32 chars, unique staging value)
PAYLOAD_SECRET=

# Public staging URL (no trailing slash) — used at build time for SEO/OG
NEXT_PUBLIC_SERVER_URL=https://staging.example.com

# Preview & cron (optional)
PREVIEW_SECRET=
CRON_SECRET=
