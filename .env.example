# PostgreSQL connection string
DATABASE_URI=postgresql://gpi:gpi@127.0.0.1:5432/gpi

# Used to encrypt JWT tokens (min 32 chars)
PAYLOAD_SECRET=your-secret-key-min-32-characters-long

# Public site URL (no trailing slash)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Preview & cron (optional for dev)
PREVIEW_SECRET=preview-secret
CRON_SECRET=cron-secret
