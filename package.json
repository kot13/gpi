{
  "name": "gpi",
  "version": "1.0.0",
  "description": "GPI Real Estate Agency — Payload CMS + Next.js",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint . --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation tsx src/endpoints/seed/index.ts",
    "db:push": "cross-env NODE_OPTIONS=--no-deprecation PAYLOAD_FORCE_DRIZZLE_PUSH=true NODE_ENV=development tsx scripts/push-schema.ts",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts tests/unit",
    "test:integration": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts tests/integration --pool=forks --maxWorkers=1",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:coverage": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts --coverage"
  },
  "dependencies": {
    "@payloadcms/admin-bar": "3.85.0",
    "@payloadcms/db-postgres": "3.85.0",
    "@payloadcms/live-preview-react": "3.85.0",
    "@payloadcms/next": "3.85.0",
    "@payloadcms/plugin-nested-docs": "3.85.0",
    "@payloadcms/plugin-redirects": "3.85.0",
    "@payloadcms/plugin-seo": "3.85.0",
    "@payloadcms/richtext-lexical": "3.85.0",
    "@payloadcms/ui": "3.85.0",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cross-env": "10.1.0",
    "dotenv": "16.4.7",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "geist": "^1.3.0",
    "graphql": "^16.8.2",
    "lucide-react": "0.563.0",
    "next": "15.3.3",
    "next-intl": "^4.1.0",
    "next-sitemap": "^4.2.3",
    "payload": "3.85.0",
    "prism-react-renderer": "^2.4.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "7.71.1",
    "sharp": "0.34.2",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.15.21",
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.5",
    "@vitejs/plugin-react": "4.5.2",
    "@vitest/coverage-v8": "4.1.6",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.3.3",
    "jsdom": "26.1.0",
    "postcss": "^8.4.38",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.18",
    "tsx": "4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.8.3",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "4.1.6"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
